

{%- assign block_settings = block.settings -%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
        class="link"
      >
        {{- closest.product.title }}
      </a>
    </div>
    {% if block_settings.product_category != blank %}
      <div class="product-category">{{ block_settings.product_category | escape }}</div>
    {% endif %}
    <p class="product-tagline" data-product-tagline hidden></p>
    <div class="reviews-bar" data-reviews-bar>
      <div class="stars" aria-hidden="true">
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
      </div>
      <span class="review-count"><strong>{{ block_settings.reviews_rating | default: '4.9' | escape }}</strong> {{ block_settings.reviews_text | default: 'de 1.200+ resenas' | escape }}</span>
    </div>
    <div class="stock-indicator low-stock" data-stock-indicator>
      <span class="stock-text low-stock">{{ block_settings.stock_indicator_text | escape }}</span>
    </div>
    <div class="shipping-note" id="shippingMessage" data-shipping-note>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 13l4 4L19 7"></path>
      </svg>
      <span>{{ block_settings.shipping_note_text | default: 'Envio disponible a todo el mundo' | escape }}</span>
    </div>
    <div class="trust-row" data-trust-row>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"></rect><path d="M16 8h4l3 3v5h-7V8z"></path><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        <span class="trust-text">{{ block_settings.trust_item_1_text | default: 'Envio rapido' | escape }}</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        <span class="trust-text">{{ block_settings.trust_item_2_text | default: 'Soporte 24/7' | escape }}</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"></path><path d="M3 12h3m15 0h-3"></path></svg>
        <span class="trust-text">{{ block_settings.trust_item_3_text | default: 'Devoluciones en 90 dias' | escape }}</span>
      </div>
    </div>
    <div class="value-section" data-value-section>
      <div class="value-header">
        <div class="value-title">{{ block_settings.value_section_title | default: 'Sistema completo de entrenamiento' | escape }}</div>
        <div class="value-total">
          <span class="strike" data-total-value-header>{{ block_settings.value_total_compare_price | default: '€213,95' | escape }}</span>
          <span class="current" data-package-price>{{ block_settings.value_total_current_price | default: '€29,95' | escape }}</span>
        </div>
      </div>
      <div class="value-items">
        <div class="value-item">
          <div class="value-item-icon">{{ block_settings.value_item_1_icon | default: '📱' }}</div>
          <div class="value-item-content">
            <div class="value-item-name">{{ block_settings.value_item_1_name | default: 'App Elevate' | escape }}</div>
            <div class="value-item-desc">{{ block_settings.value_item_1_desc | default: 'Mas de 100 tutoriales (€99,00)' | escape }}</div>
          </div>
        </div>
        <div class="value-item">
          <div class="value-item-icon">{{ block_settings.value_item_2_icon | default: '🧠' }}</div>
          <div class="value-item-content">
            <div class="value-item-name">{{ block_settings.value_item_2_name | default: 'Codigo Elevate' | escape }}</div>
            <div class="value-item-desc">{{ block_settings.value_item_2_desc | default: 'Guia de mentalidad (€27,00)' | escape }}</div>
          </div>
        </div>
        <div class="value-item">
          <div class="value-item-icon">{{ block_settings.value_item_3_icon | default: '📖' }}</div>
          <div class="value-item-content">
            <div class="value-item-name">{{ block_settings.value_item_3_name | default: 'Guia de nutricion' | escape }}</div>
            <div class="value-item-desc">{{ block_settings.value_item_3_desc | default: 'Mas de 30 comidas (€39,00)' | escape }}</div>
          </div>
        </div>
        <div class="value-item">
          <div class="value-item-icon">{{ block_settings.value_item_4_icon | default: '✅' }}</div>
          <div class="value-item-content">
            <div class="value-item-name">{{ block_settings.value_item_4_name | default: 'Seguimiento' | escape }}</div>
            <div class="value-item-desc">{{ block_settings.value_item_4_desc | default: 'Acceso por 1 ano (€19,00)' | escape }}</div>
          </div>
        </div>
      </div>
    </div>
    <div class="features-section" data-features-section>
      <h2 class="features-title">{{ block_settings.features_title | default: 'Por que esta cuerda lo cambia todo' | escape }}</h2>

      <div class="feature-item">
        <div class="feature-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="feature-content">
          <div class="feature-benefit">{{ block_settings.feature_1_title | default: 'Control de ritmo perfecto' | escape }}</div>
          <div class="feature-detail">{{ block_settings.feature_1_desc | default: 'Las cuentas segmentadas crean un peso optimo y retroalimentacion tactil' | escape }}</div>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="feature-content">
          <div class="feature-benefit">{{ block_settings.feature_2_title | default: 'Sistema completo de entrenamiento' | escape }}</div>
          <div class="feature-detail">{{ block_settings.feature_2_desc | default: 'Mas de 100 tutoriales, planes de comida y seguimiento de progreso' | escape }}</div>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="feature-content">
          <div class="feature-benefit">{{ block_settings.feature_3_title | default: 'Disenada para entrenamiento intenso' | escape }}</div>
          <div class="feature-detail">{{ block_settings.feature_3_desc | default: 'Cuentas duraderas con mangos resistentes a impactos' | escape }}</div>
        </div>
      </div>
    </div>
    <div class="guarantee-section" data-guarantee-section>
      <div class="guarantee-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
      </div>
      <div class="guarantee-content">
        <div class="guarantee-title">{{ block_settings.guarantee_title | default: 'Mango de por vida + Proteccion de 90 dias' | escape }}</div>
        <div class="guarantee-text">{{ block_settings.guarantee_text | default: 'Se rompe el mango? Reemplazo gratis. No estas satisfecho? Reembolso completo.' | escape }}</div>
      </div>
    </div>
    <div class="product__payment" data-product-payment>
      <ul class="list list-payment" role="list">
        {%- assign payment_types = shop.enabled_payment_types -%}
        {%- if payment_types == blank or payment_types.size == 0 -%}
          {%- assign payment_types = 'american_express,apple_pay,bancontact,google_pay,ideal,klarna,maestro,master,mobilepay,paypal,shopify_pay,unionpay,usdc,visa' | split: ',' -%}
        {%- endif -%}
        {%- for type in payment_types -%}
          {%- capture payment_icon -%}{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}{%- endcapture -%}
          {%- if payment_icon != blank -%}
            <li class="list-payment__item">
              {{ payment_icon }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
    <div class="product__accordion accordion toggle_right product-description-accordion" data-description-accordion hidden>
      <details class="dt-details">
        <summary>
          <div class="summary__title">
            <svg class="icon icon-accordion color-foreground-accent-2" aria-hidden="true" focusable="false" role="presentation" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><path d="M18.5 1.5H1.5L1.5 18.5H18.5V1.5ZM1.5 0.5C0.947715 0.5 0.5 0.947715 0.5 1.5V18.5C0.5 19.0523 0.947715 19.5 1.5 19.5H18.5C19.0523 19.5 19.5 19.0523 19.5 18.5V1.5C19.5 0.947715 19.0523 0.5 18.5 0.5H1.5Z" fill-rule="evenodd"></path><path d="M14.9975 6.09084C15.201 6.27746 15.2147 6.59375 15.0281 6.79728L8.91631 13.4627C8.82231 13.5652 8.68987 13.6239 8.55079 13.6247C8.41172 13.6256 8.27857 13.5684 8.18335 13.4671L4.99513 10.0731C4.80606 9.87179 4.81596 9.55536 5.01723 9.3663C5.21849 9.17723 5.53492 9.18713 5.72399 9.3884L8.54335 12.3897L14.291 6.12145C14.4776 5.91791 14.7939 5.90421 14.9975 6.09084Z"></path></svg>
            <h6 class="accordion__title">Descripción</h6>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-caret" width="8.828" height="5.414" viewBox="0 0 8.828 5.414"><path d="M4,10,7,7,4,4" transform="translate(11.414 -2.586) rotate(90)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1"></path></svg>
        </summary>
        <div class="accordion__content rte">
          <p><strong>Elevate Storm Beaded Jump Rope – Tu puerta de entrada a la maestría en cuerda para saltar</strong></p>
          <p>Embárcate en tu viaje fitness con la <strong>Storm Beaded Jump Rope</strong>, diseñada meticulosamente como la <strong>cuerda para saltar con cuentas</strong> definitiva. Ya sea que busques mejorar la coordinación, aumentar la resistencia o simplemente disfrutar de un entrenamiento divertido, esta cuerda es tu compañera perfecta.</p>
          <p><strong>Características Clave:</strong></p>
          <ul>
            <li><strong>Longitud ajustable:</strong> Ajusta la cuerda a tu altura para un rendimiento óptimo, asegurando un entrenamiento cómodo y efectivo.</li>
            <li><strong>Construcción duradera:</strong> Fabricada con materiales de alta calidad, esta cuerda resiste un uso riguroso, convirtiéndola en una opción confiable para entrenamientos diarios.</li>
            <li><strong>Retroalimentación mejorada:</strong> El diseño con cuentas proporciona retroalimentación táctil, ayudando con el ritmo y la sincronización, esencial para que los principiantes dominen las técnicas de salto.</li>
            <li><strong>Diseño libre de enredos:</strong> Diseñada para evitar enredos, permitiendo sesiones ininterrumpidas y transiciones fluidas entre movimientos.</li>
          </ul>
          <p>La <strong>Storm Beaded Jump Rope</strong> no es solo una herramienta; es una inversión en tu salud y estado físico. Su diseño está pensado para quienes buscan una <strong>cuerda para saltar duradera para rutinas de estilo libre</strong> y para quienes desean mejorar su <strong>coordinación</strong> y <strong>agilidad</strong>.</p>
          <p><strong>¿Por qué elegir la Storm Beaded Jump Rope?</strong></p>
          <p>Saltar la cuerda es un entrenamiento eficiente en tiempo, de cuerpo completo, que mejora la salud cardiovascular, quema calorías y realza el tono muscular. La <strong>Storm Beaded Jump Rope</strong> amplifica estos beneficios al ofrecer una experiencia fácil de usar, especialmente para principiantes.</p>
          <p><strong>Complementa tu entrenamiento:</strong></p>
          <p>Explora nuestra gama de cuerdas para saltar y accesorios para elevar tu rutina de fitness: <a href="https://www.elevaterope.com/collections/all" rel="noopener noreferrer" target="_blank">Colecciones Elevate Rope</a>.</p>
          <p><strong>Perspectiva de experto:</strong></p>
          <p>Para obtener consejos y técnicas adicionales sobre fitness con cuerda para saltar, visita <a href="https://www.youtube.com/@GeraldoAlken" rel="noopener noreferrer" target="_blank">el canal de YouTube de Geraldo Alkens</a>, una fuente confiable para los entusiastas de la cuerda para saltar.</p>
        </div>
      </details>
    </div>
    <div class="product__accordion accordion product-shipping-accordion" data-shipping-accordion>
      <details class="dt-details">
        <summary>
          <div class="summary__title">
            <svg class="icon icon-accordion color-foreground-accent-2" aria-hidden="true" focusable="false" role="presentation" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><path d="M0 3.75156C0 3.47454 0.224196 3.24997 0.500755 3.24997H10.647C10.9235 3.24997 11.1477 3.47454 11.1477 3.75156V5.07505V5.63362V6.10938V13.6616C10.9427 14.0067 10.8813 14.1101 10.5516 14.6648L7.22339 14.6646V13.6614H10.1462V4.25316H1.00151V13.6614H2.6842V14.6646H0.500755C0.224196 14.6646 0 14.44 0 14.163V3.75156Z"></path><path d="M18.9985 8.08376L11.1477 6.10938V5.07505L19.6212 7.20603C19.8439 7.26203 20 7.46255 20 7.69253V14.1631C20 14.4401 19.7758 14.6647 19.4992 14.6647H17.3071V13.6615H18.9985V8.08376ZM11.1477 13.6616L13.3442 13.6615L13.3443 14.6647L10.5516 14.6648L11.1477 13.6616Z"></path><path d="M7.71269 14.1854C7.71269 15.6018 6.56643 16.75 5.15245 16.75C3.73847 16.75 2.59221 15.6018 2.59221 14.1854C2.59221 12.7691 3.73847 11.6209 5.15245 11.6209C6.56643 11.6209 7.71269 12.7691 7.71269 14.1854ZM5.15245 15.7468C6.01331 15.7468 6.71118 15.0478 6.71118 14.1854C6.71118 13.3231 6.01331 12.6241 5.15245 12.6241C4.29159 12.6241 3.59372 13.3231 3.59372 14.1854C3.59372 15.0478 4.29159 15.7468 5.15245 15.7468Z"></path><path d="M17.5196 14.1854C17.5196 15.6018 16.3733 16.75 14.9593 16.75C13.5454 16.75 12.3991 15.6018 12.3991 14.1854C12.3991 12.7691 13.5454 11.6209 14.9593 11.6209C16.3733 11.6209 17.5196 12.7691 17.5196 14.1854ZM14.9593 15.7468C15.8202 15.7468 16.5181 15.0478 16.5181 14.1854C16.5181 13.3231 15.8202 12.6241 14.9593 12.6241C14.0985 12.6241 13.4006 13.3231 13.4006 14.1854C13.4006 15.0478 14.0985 15.7468 14.9593 15.7468Z"></path></svg>
            <h6 class="accordion__title">Información de envío</h6>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-caret" width="8.828" height="5.414" viewBox="0 0 8.828 5.414"><path d="M4,10,7,7,4,4" transform="translate(11.414 -2.586) rotate(90)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1"></path></svg>
        </summary>
        <div class="accordion__content rte">
          <h3>Tiempos de entrega</h3>
          <p><strong>Países Bajos</strong></p>
          <ul><li>Tiempo de manejo: 0-2 días hábiles</li><li>Tiempo de tránsito: 1-3 días hábiles (lunes-viernes)</li></ul>
          <p><strong>Benelux</strong></p>
          <ul><li>Tiempo de manejo: 0-2 días hábiles</li><li>Tiempo de tránsito: 2-4 días hábiles (lunes-viernes)</li></ul>
          <p><strong>Resto de Europa</strong></p>
          <ul><li>Tiempo de manejo: 0-2 días hábiles</li><li>Tiempo de tránsito: 3-7 días hábiles (lunes-viernes)</li></ul>
          <p><strong>Resto del mundo</strong></p>
          <ul><li>Tiempo de manejo: 0-2 días hábiles</li><li>Tiempo de tránsito: 5-10 días hábiles (lunes-viernes)</li></ul>
          <p><em>El tiempo de manejo se refiere al tiempo necesario para procesar su pedido antes del envío.<br>El tiempo de tránsito se refiere al tiempo que el transportista necesita para entregar su pedido después del despacho.<br>Los días hábiles excluyen fines de semana y días festivos.</em></p>
          <h3>Costos de envío</h3>
          <p><strong>Países Bajos</strong></p>
          <ul><li>Tarifa de envío de 6,95 EUR</li><li>Envío gratuito para pedidos superiores a 125 EUR</li></ul>
          <p><strong>Benelux</strong></p>
          <ul><li>Tarifa de envío de 9,95 EUR</li><li>Envío gratuito para pedidos superiores a 125 EUR</li></ul>
          <p><strong>Italia</strong></p>
          <ul><li>Tarifa de envío de 9,95 EUR</li><li>Envío gratuito para pedidos superiores a 125 EUR</li></ul>
          <p><strong>Resto de Europa</strong></p>
          <ul><li>Tarifa de envío de 12,95 EUR</li><li>No hay envío gratuito disponible</li></ul>
          <p><strong>USA</strong></p>
          <ul><li>Tarifa de envío de 9,95 USD</li><li>Envío gratuito para pedidos superiores a 125 USD</li></ul>
          <p><strong>Canadá</strong></p>
          <ul><li>Tarifa de envío de 14,95 CAD</li><li>Envío gratuito para pedidos superiores a 125 CAD</li></ul>
          <p><strong>Australia</strong></p>
          <ul><li>Tarifa de envío de 9,95 AUD</li><li>Envío gratuito para pedidos superiores a 125 AUD</li></ul>
          <p><strong>Nueva Zelanda</strong></p>
          <ul><li>Tarifa de envío de 14,95 EUR</li><li>Envío gratuito para pedidos superiores a 125 EUR</li></ul>
          <p><strong>Resto del mundo</strong></p>
          <ul><li>Tarifa de envío de 19,95 EUR</li><li>No hay envío gratuito disponible</li></ul>
          <h3>Notas importantes</h3>
          <ul>
            <li>Los tiempos de envío son estimados y pueden variar debido a la ubicación, retrasos del transportista o despacho de aduanas.</li>
            <li>Se proporcionará un número de seguimiento una vez que su pedido haya sido enviado.</li>
            <li>Los costos de envío se calculan automáticamente al finalizar la compra según su ubicación de entrega y el total del pedido.</li>
          </ul>
        </div>
      </details>
    </div>
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 12px;
    }

    .product-details .group-block-content > .product-category + .group-block {
      margin-top: -18px;
    }

    .product-category {
      box-sizing: border-box;
      color: rgb(85, 16, 221);
      cursor: pointer;
      display: block;
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 11px;
      font-style: normal;
      font-weight: 700;
      height: 16.5px;
      letter-spacing: 0.8px;
      line-height: 16.5px;
      list-style-image: none;
      list-style-position: outside;
      list-style-type: none;
      margin-top: 0;
      margin-right: 0;
      margin-bottom: 6px;
      margin-left: 0;
      padding-top: 0;
      padding-right: 0;
      padding-bottom: 0;
      padding-left: 0;
      scrollbar-width: none;
      text-transform: uppercase;
      unicode-bidi: isolate;
      width: 330.4px;
      max-width: 100%;
      -webkit-font-smoothing: antialiased;
    }
  }

  .view-product-title {
    display: none;
  }

  .product-tagline {
    box-sizing: border-box;
    color: rgb(115, 115, 115);
    display: block;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    font-style: normal;
    font-weight: 300;
    height: 21px;
    line-height: 21px;
    list-style-image: none;
    list-style-position: outside;
    list-style-type: none;
    margin-block-start: 0;
    margin-block-end: 0;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
    unicode-bidi: isolate;
    width: 635.4px;
    max-width: 100%;
    -webkit-font-smoothing: antialiased;
  }

  @media screen and (max-width: 749px) {
    .product-tagline {
      width: 100%;
      height: auto;
    }
  }

  .product-description-dynamic {
    box-sizing: border-box;
    color: rgb(115, 115, 115);
    display: block;
