

{%- assign block_settings = block.settings -%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
        class="link"
      >
        {{- closest.product.title }}
      </a>
    </div>
    {% if block_settings.product_category != blank %}
      <div class="product-category">{{ block_settings.product_category | escape }}</div>
    {% endif %}
    <p class="product-tagline" data-product-tagline>
      Segmented beads create audible feedback for perfect timing. The easiest way to learn.
    </p>
    <div class="reviews-bar" data-reviews-bar>
      <div class="stars" aria-hidden="true">
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
        <svg class="star" viewBox="0 0 20 20"><path fill="currentColor" d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"></path></svg>
      </div>
      <span class="review-count"><strong>4.9</strong> from 1,200+ reviews</span>
    </div>
    <div class="stock-indicator low-stock" data-stock-indicator>
      <span class="stock-text low-stock">{{ block_settings.stock_indicator_text | escape }}</span>
    </div>
    <div class="shipping-note" id="shippingMessage" data-shipping-note>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 13l4 4L19 7"></path>
      </svg>
      <span>Worldwide shipping available</span>
    </div>
    <div class="trust-row" data-trust-row>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"></rect><path d="M16 8h4l3 3v5h-7V8z"></path><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        <span class="trust-text">Fast Shipping</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        <span class="trust-text">24/7 Support</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"></path><path d="M3 12h3m15 0h-3"></path></svg>
        <span class="trust-text">90-Day Returns</span>
      </div>
    </div>
    <div class="value-section" data-value-section>
      <div class="value-header">
        <div class="value-title">Complete Training System</div>
        <div class="value-total">
          <span class="strike" data-total-value-header>€213,95</span>
          <span class="current" data-package-price>€29,95</span>
        </div>
      </div>
      <div class="value-items">
        <div class="value-item">
          <div class="value-item-icon">📱</div>
          <div class="value-item-content">
            <div class="value-item-name">Elevate App</div>
            <div class="value-item-desc">100+ tutorials (€99,00)</div>
          </div>
        </div>
        <div class="value-item">
          <div class="value-item-icon">🧠</div>
          <div class="value-item-content">
            <div class="value-item-name">Elevate Code</div>
            <div class="value-item-desc">Mindset guide (€27,00)</div>
          </div>
        </div>
        <div class="value-item">
          <div class="value-item-icon">📖</div>
          <div class="value-item-content">
            <div class="value-item-name">Nutrition Guide</div>
            <div class="value-item-desc">30+ meals (€39,00)</div>
          </div>
        </div>
        <div class="value-item">
          <div class="value-item-icon">✅</div>
          <div class="value-item-content">
            <div class="value-item-name">Tracker</div>
            <div class="value-item-desc">1 year access (€19,00)</div>
          </div>
        </div>
      </div>
    </div>
    <div class="features-section" data-features-section>
      <h2 class="features-title">Why This Rope Changes Everything</h2>

      <div class="feature-item">
        <div class="feature-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="feature-content">
          <div class="feature-benefit">Perfect rhythm control</div>
          <div class="feature-detail">Segmented beads create optimal weight and tactile feedback</div>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="feature-content">
          <div class="feature-benefit">Complete training system</div>
          <div class="feature-detail">100+ tutorials, meal plans &amp; accountability tracking</div>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="feature-content">
          <div class="feature-benefit">Built for intense training</div>
          <div class="feature-detail">Durable beads with shatter-resistant handles</div>
        </div>
      </div>
    </div>
    <div class="guarantee-section" data-guarantee-section>
      <div class="guarantee-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
      </div>
      <div class="guarantee-content">
        <div class="guarantee-title">Lifetime Handle + 90-Day Protection</div>
        <div class="guarantee-text">Handles break? Free replacement. Not satisfied? Full refund.</div>
      </div>
    </div>
    <div class="product__payment" data-product-payment>
      <ul class="list list-payment" role="list">
        {%- assign payment_types = shop.enabled_payment_types -%}
        {%- if payment_types == blank or payment_types.size == 0 -%}
          {%- assign payment_types = 'american_express,apple_pay,bancontact,google_pay,ideal,klarna,maestro,master,mobilepay,paypal,shopify_pay,unionpay,usdc,visa' | split: ',' -%}
        {%- endif -%}
        {%- for type in payment_types -%}
          {%- capture payment_icon -%}{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}{%- endcapture -%}
          {%- if payment_icon != blank -%}
            <li class="list-payment__item">
              {{ payment_icon }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 12px;
    }

    .product-details .group-block-content > .product-category + .group-block {
      margin-top: -18px;
    }

    .product-category {
      box-sizing: border-box;
      color: rgb(85, 16, 221);
      cursor: pointer;
      display: block;
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 11px;
      font-style: normal;
      font-weight: 700;
      height: 16.5px;
      letter-spacing: 0.8px;
      line-height: 16.5px;
      list-style-image: none;
      list-style-position: outside;
      list-style-type: none;
      margin-top: 0;
      margin-right: 0;
      margin-bottom: 6px;
      margin-left: 0;
      padding-top: 0;
      padding-right: 0;
      padding-bottom: 0;
      padding-left: 0;
      scrollbar-width: none;
      text-transform: uppercase;
      unicode-bidi: isolate;
      width: 330.4px;
      max-width: 100%;
      -webkit-font-smoothing: antialiased;
    }
  }

  .view-product-title {
    display: none;
  }

  .product-tagline {
    box-sizing: border-box;
    color: rgb(115, 115, 115);
    display: block;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    font-style: normal;
    font-weight: 300;
    height: 21px;
    line-height: 21px;
    list-style-image: none;
    list-style-position: outside;
    list-style-type: none;
    margin-block-start: 0;
    margin-block-end: 0;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
    unicode-bidi: isolate;
    width: 635.4px;
    max-width: 100%;
    -webkit-font-smoothing: antialiased;
  }

  @media screen and (max-width: 749px) {
    .product-tagline {
      width: 100%;
      height: auto;
    }
  }

  .reviews-bar {
    align-items: center;
    border-top-color: rgb(245, 245, 245);
    border-top-style: solid;
    border-top-width: 0.8px;
    box-sizing: border-box;
    color: rgb(23, 23, 23);
    column-gap: 8px;
    display: flex;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 700;
    height: 49.8px;
    line-height: 21px;
    list-style-image: none;
    list-style-position: outside;
    list-style-type: none;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 12px;
    margin-left: 0;
    padding-top: 14px;
    padding-right: 0;
    padding-bottom: 14px;
    padding-left: 0;
    row-gap: 8px;
    unicode-bidi: isolate;
    width: 635.4px;
    max-width: 100%;
    -webkit-font-smoothing: antialiased;
  }

  .reviews-bar .stars {
    display: inline-flex;
    gap: 2px;
