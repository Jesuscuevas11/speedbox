<script>
  (() => {
    const moveDetailsExtras = () => {
      const root = document.getElementById('ProductInformation-{{ section.id }}');
      if (!root) return;

      const tagline = root.querySelector('[data-product-tagline]');
      const bar = root.querySelector('[data-reviews-bar]');
      const stock = root.querySelector('[data-stock-indicator]');
      const shipping = root.querySelector('[data-shipping-note]');
      const trust = root.querySelector('[data-trust-row]');
      const value = root.querySelector('[data-value-section]');
      const features = root.querySelector('[data-features-section]');
      const guarantee = root.querySelector('[data-guarantee-section]');
      const payment = root.querySelector('[data-product-payment]');
      const title = root.querySelector('.text-block:is(.h1, .h2, .h3, .h4, .h5, .h6) > h1');
      if (!title) return;

      const titleBlock = title.closest('.text-block');
      if (!titleBlock) return;

      if (tagline && titleBlock.nextElementSibling !== tagline) {
        titleBlock.insertAdjacentElement('afterend', tagline);
      }

      if (bar && (!tagline || tagline.nextElementSibling !== bar)) {
        (tagline || titleBlock).insertAdjacentElement('afterend', bar);
      }

      if (stock && (!bar || bar.nextElementSibling !== stock)) {
        (bar || tagline || titleBlock).insertAdjacentElement('afterend', stock);
      }

      const addToCart = root.querySelector('.product-form-buttons add-to-cart-component');
      if (shipping && addToCart && addToCart.parentElement && addToCart.parentElement.nextElementSibling !== shipping) {
        addToCart.parentElement.insertAdjacentElement('afterend', shipping);
      }

      if (trust && shipping && shipping.nextElementSibling !== trust) {
        shipping.insertAdjacentElement('afterend', trust);
      }

      if (value && trust && trust.nextElementSibling !== value) {
        trust.insertAdjacentElement('afterend', value);
      }

      if (features && value && value.nextElementSibling !== features) {
        value.insertAdjacentElement('afterend', features);
      }

      if (guarantee && features && features.nextElementSibling !== guarantee) {
        features.insertAdjacentElement('afterend', guarantee);
      }

      if (payment && guarantee && guarantee.nextElementSibling !== payment) {
        guarantee.insertAdjacentElement('afterend', payment);
      }
    };

    moveDetailsExtras();
    document.addEventListener('shopify:section:load', moveDetailsExtras);
  })();
</script>

