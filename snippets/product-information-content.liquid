<script>
  (() => {
    const customers = [
      { name: 'Carlos R.', location: 'Madrid', product: 'Athlete Bundle' },
      { name: 'Sarah M.', location: 'London', product: 'Ascent MAX Bundle' },
      { name: 'Anna K.', location: 'Berlin', product: 'Athlete Bundle' },
      { name: 'James L.', location: 'Sydney', product: 'Ascent Bundle' },
      { name: 'Emma S.', location: 'Toronto', product: 'Ascent MAX Bundle' },
    ];

    const initSocialProof = (root) => {
      if (!root || root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const viewerCount = root.querySelector('[data-viewer-count]');
      const countdown = root.querySelector('[data-countdown]');
      const shippingTitle = root.querySelector('[data-shipping-title]');
      const shippingDescription = root.querySelector('[data-shipping-description]');
      const modal = root.querySelector('[data-video-modal]');
      const videoFrame = root.querySelector('[data-video-frame]');
      const notification = root.querySelector('[data-notification]');
      const notificationImage = root.querySelector('[data-notification-image]');
      const notificationName = root.querySelector('[data-notification-name]');
      const notificationAction = root.querySelector('[data-notification-action]');
      const notificationTime = root.querySelector('[data-notification-time]');
      const notificationClose = root.querySelector('[data-notification-close]');
      const imageSrc = root.dataset.productImage;
      let customerIndex = 0;

      const updateViewerCount = () => {
        if (!viewerCount) return;
        viewerCount.textContent = String(Math.floor(Math.random() * 30) + 35);
      };

      const updateCountdown = () => {
        if (!countdown) return;
        const now = new Date();
        const cutoff = new Date(now);
        cutoff.setHours(21, 0, 0, 0);

        if (now >= cutoff) {
          cutoff.setDate(cutoff.getDate() + 1);
        }

        const diff = cutoff - now;
        const hours = Math.floor(diff / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        countdown.textContent = `${hours}h ${minutes}m`;
      };

      const updateShippingInfo = () => {
        if (!shippingTitle || !shippingDescription) return;
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
        const locale = (navigator.language || '').toLowerCase();

        if (timezone.includes('Europe') || ['de', 'fr', 'it', 'es', 'nl', 'be', 'at', 'pt', 'ie', 'se', 'dk', 'fi', 'no'].some((code) => locale.startsWith(code))) {
          shippingTitle.textContent = 'Free Shipping Over €50';
          shippingDescription.textContent = 'Fast delivery to EU, UK, US, Canada and Australia. Worldwide available.';
          return;
        }

        if (timezone.includes('London') || locale.startsWith('en-gb')) {
          shippingTitle.textContent = 'Free Shipping Over £42.50';
          shippingDescription.textContent = 'Fast delivery to EU, UK, US, Canada and Australia. Worldwide available.';
          return;
        }

        if (timezone.includes('America') || locale.startsWith('en-us')) {
          shippingTitle.textContent = 'Free Shipping Over $54';
          shippingDescription.textContent = 'Fast delivery to EU, UK, US, Canada and Australia. Worldwide available.';
          return;
        }

        shippingTitle.textContent = 'Worldwide Shipping Available';
        shippingDescription.textContent = 'Fast international delivery. Free shipping available in select regions.';
      };

      const showNotification = () => {
        if (!notification) return;
        const customer = customers[customerIndex % customers.length];
        customerIndex += 1;
        if (notificationImage && imageSrc) notificationImage.src = imageSrc;
        if (notificationName) notificationName.textContent = `${customer.name} from ${customer.location}`;
        if (notificationAction) notificationAction.textContent = `just purchased ${customer.product}`;
        if (notificationTime) notificationTime.textContent = `${Math.floor(Math.random() * 5) + 1} minutes ago`;
        notification.hidden = false;
        window.setTimeout(() => {
          notification.hidden = true;
        }, 5000);
      };

      root.querySelectorAll('[data-video-id]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!modal || !videoFrame) return;
          const videoId = button.getAttribute('data-video-id');
          videoFrame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
          modal.hidden = false;
          document.body.style.overflow = 'hidden';
        });
      });

      root.querySelector('[data-close-video]')?.addEventListener('click', () => {
        if (!modal || !videoFrame) return;
        modal.hidden = true;
        videoFrame.src = '';
        document.body.style.overflow = '';
      });

      modal?.addEventListener('click', (event) => {
        if (event.target !== modal || !videoFrame) return;
        modal.hidden = true;
        videoFrame.src = '';
        document.body.style.overflow = '';
      });

      notificationClose?.addEventListener('click', () => {
        if (notification) notification.hidden = true;
      });

      updateViewerCount();
      updateCountdown();
      updateShippingInfo();
      window.setInterval(updateViewerCount, 8000);
      window.setInterval(updateCountdown, 60000);
      window.setTimeout(showNotification, 3000);
      window.setInterval(showNotification, 30000);
    };

    const initMulticolumnCarousel = (root) => {
      if (!root || root.dataset.carouselInitialized === 'true') return;

      const list = root.querySelector('.pdp-multicolumn__list');
      const slides = list ? Array.from(list.querySelectorAll('.pdp-multicolumn__item')) : [];
      const dotsContainer = root.querySelector('[data-multi-dots]');

      if (!list || slides.length < 2 || !dotsContainer) return;

      root.dataset.carouselInitialized = 'true';

      let currentIndex = 0;
      let autoplayId = null;

      const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

      const renderDots = () => {
        dotsContainer.innerHTML = '';
        slides.forEach((_, index) => {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'pdp-multicolumn__dot';
          dot.setAttribute('aria-label', `Ir a slide ${index + 1}`);
          dot.setAttribute('aria-current', index === currentIndex ? 'true' : 'false');
          dot.addEventListener('click', () => {
            goToSlide(index);
            restartAutoplay();
          });
          dotsContainer.appendChild(dot);
        });
      };

      const updateDots = () => {
        const dots = dotsContainer.querySelectorAll('.pdp-multicolumn__dot');
        dots.forEach((dot, index) => {
          dot.setAttribute('aria-current', index === currentIndex ? 'true' : 'false');
        });
      };

      const goToSlide = (index, behavior = 'smooth') => {
        currentIndex = (index + slides.length) % slides.length;
        if (isMobile()) {
          const target = slides[currentIndex];
          list.scrollTo({ left: target.offsetLeft, behavior });
        }
        updateDots();
      };

      const syncIndexFromScroll = () => {
        if (!isMobile()) return;
        const center = list.scrollLeft + list.clientWidth / 2;
        let closestIndex = 0;
        let closestDistance = Number.POSITIVE_INFINITY;

        slides.forEach((slide, index) => {
          const slideCenter = slide.offsetLeft + slide.clientWidth / 2;
          const distance = Math.abs(center - slideCenter);
          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        if (closestIndex !== currentIndex) {
          currentIndex = closestIndex;
          updateDots();
        }
      };

      const stopAutoplay = () => {
        if (autoplayId) {
          window.clearInterval(autoplayId);
          autoplayId = null;
        }
      };

      const startAutoplay = () => {
        stopAutoplay();
        if (!isMobile()) return;
        autoplayId = window.setInterval(() => {
          goToSlide(currentIndex + 1);
        }, 4500);
      };

      const restartAutoplay = () => {
        stopAutoplay();
        startAutoplay();
      };

      renderDots();
      goToSlide(0, 'auto');
      startAutoplay();

      list.addEventListener('scroll', syncIndexFromScroll, { passive: true });
      list.addEventListener('pointerdown', stopAutoplay, { passive: true });
      list.addEventListener('pointerup', startAutoplay, { passive: true });
      window.addEventListener('resize', () => {
        goToSlide(currentIndex, 'auto');
        restartAutoplay();
      });
    };

    const initTimeline = (root) => {
      if (!root || root.dataset.timelineInitialized === 'true') return;
      root.dataset.timelineInitialized = 'true';

      const items = Array.from(root.querySelectorAll('.pdp-timeline__item'));
      if (!items.length) return;

      let lastScrollY = window.scrollY;
      let scrollDirection = 'down';

      window.addEventListener('scroll', () => {
        scrollDirection = window.scrollY > lastScrollY ? 'down' : 'up';
        lastScrollY = window.scrollY;
      }, { passive: true });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const item = entry.target;
          const dot = item.querySelector('.pdp-timeline__dot circle');

          if (!dot) return;

          if (scrollDirection === 'down') {
            if (entry.isIntersecting) {
              item.style.setProperty('--after-height', '100%');
              dot.style.fill = '#000';
            }
            return;
          }

          if (entry.isIntersecting) {
            item.style.setProperty('--after-height', '100%');
            dot.style.fill = '#000';
          } else {
            item.style.setProperty('--after-height', '0%');
            dot.style.fill = '#fff';
          }
        });
      }, { threshold: 0.5 });

      items.forEach((item) => observer.observe(item));
    };

    const initTabsSection = (root) => {
      if (!root || root.dataset.tabsInitialized === 'true') return;
      root.dataset.tabsInitialized = 'true';

      const nav = root.querySelector('.pdp-tabs__nav');
      const navItems = Array.from(root.querySelectorAll('.pdp-tabs__nav li'));
      const navButtons = Array.from(root.querySelectorAll('.pdp-tabs__tab'));
      const panels = Array.from(root.querySelectorAll('.pdp-tabs__panel'));

      if (!nav || !navButtons.length || !panels.length) return;

      const setActive = (tabId) => {
        navItems.forEach((item) => {
          const button = item.querySelector('.pdp-tabs__tab');
          const isActive = button && button.dataset.tabTarget === tabId;
          item.classList.toggle('is-active', Boolean(isActive));
          if (button) button.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        panels.forEach((panel) => {
          panel.classList.toggle('is-active', panel.id === tabId);
        });
      };

      nav.addEventListener('click', (event) => {
        const button = event.target.closest('.pdp-tabs__tab');
        if (!button || !nav.contains(button)) return;
        event.preventDefault();
        event.stopPropagation();
        if (!button.dataset.tabTarget) return;
        setActive(button.dataset.tabTarget);
      });

      const initiallyActive = nav.querySelector('.pdp-tabs__tab[aria-selected="true"]') || navButtons[0];
      if (initiallyActive && initiallyActive.dataset.tabTarget) {
        setActive(initiallyActive.dataset.tabTarget);
      }

      panels.forEach((panel) => {
        const mobileTitle = panel.querySelector('.pdp-tabs__mobile-title');
        if (!mobileTitle) return;
        mobileTitle.addEventListener('click', (event) => {
          event.preventDefault();
          if (window.matchMedia('(max-width: 767px)').matches) {
            panel.classList.toggle('is-active');
            return;
          }
          setActive(panel.id);
        });
      });
    };

    const initAll = () => {
      document.querySelectorAll('[data-social-proof]').forEach(initSocialProof);
      document.querySelectorAll('[data-pdp-multicolumn]').forEach(initMulticolumnCarousel);
      document.querySelectorAll('[data-pdp-timeline]').forEach(initTimeline);
      document.querySelectorAll('[data-pdp-tabs]').forEach(initTabsSection);
    };

    initAll();
    document.addEventListener('DOMContentLoaded', initAll);
    window.addEventListener('load', initAll);
    document.addEventListener('shopify:section:load', initAll);
    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      document.querySelectorAll('[data-video-modal]').forEach((modal) => {
        const iframe = modal.querySelector('[data-video-frame]');
        modal.hidden = true;
        if (iframe) iframe.src = '';
        document.body.style.overflow = '';
      });
    });
  })();
</script>
