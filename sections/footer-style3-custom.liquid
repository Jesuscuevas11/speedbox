<footer id="Banner-{{ section.id }}" class="footer-style3 color-{{ section.settings.color_scheme }}">
  <div class="footer-style3__content-top section section--full-width spacing-style" style="{% render 'spacing-padding', settings: section.settings %}">
    <div class="footer-style3__grid">
      <div class="footer-style3__col footer-style3__col--about">
        <a href="{{ routes.root_url }}" class="footer-style3__logo-link" aria-label="Inicio">
          {% if section.settings.logo != blank %}
            {{
              section.settings.logo
              | image_url: width: 700
              | image_tag: loading: 'lazy', class: 'footer-style3__logo', alt: shop.name
            }}
          {% else %}
            <span class="footer-style3__logo-text">{{ shop.name }}</span>
          {% endif %}
        </a>
        <p class="footer-style3__text">{{ section.settings.mission_text }}</p>
      </div>

      <details class="footer-style3__col footer-style3__accordion">
        <summary class="footer-style3__heading">{{ section.settings.policy_title }}</summary>
        <div class="footer-style3__accordion-content">
          <ul class="footer-style3__list" role="list">
            <li><a href="/es/pages/terms-condtions">Terminos y Condiciones</a></li>
            <li><a href="/es/pages/privacy-policy">Politica de Privacidad</a></li>
            <li><a href="/es/pages/shipping-policy">Politica de Envio</a></li>
            <li><a href="/es/pages/cancellation-policy">Politica de cancelacion</a></li>
            <li><a href="/es/pages/refund-and-return-policy">Politica de reembolso y devoluciones</a></li>
          </ul>
        </div>
      </details>

      <details class="footer-style3__col footer-style3__accordion">
        <summary class="footer-style3__heading">{{ section.settings.info_title }}</summary>
        <div class="footer-style3__accordion-content">
          <ul class="footer-style3__list" role="list">
            <li><a href="/es/pages/contact">Contactanos</a></li>
            <li><a href="https://youtu.be/viKJE1DufVg?si=LnYaIiYLXVAWmtdY">Serie para principiantes</a></li>
            <li><a href="/es/blogs/articles/proper-jump-rope-length">Dimensionando tu cuerda para saltar</a></li>
            <li><a href="/es/pages/faq">Preguntas Frecuentes</a></li>
          </ul>
        </div>
      </details>

      <details class="footer-style3__col footer-style3__col--hq footer-style3__accordion">
        <summary class="footer-style3__heading">{{ section.settings.hq_title }}</summary>
        <div class="footer-style3__accordion-content">
          <p class="footer-style3__text">{{ section.settings.hq_text }}</p>
        </div>
      </details>
    </div>
  </div>

  <div class="footer-style3__content-bottom section section--full-width">
    <div class="footer-style3__bottom-inner">
      <small class="footer-style3__copyright">{{ section.settings.copyright_text }}</small>

      <div class="footer-style3__payments">
        <span class="visually-hidden">Metodos de pago</span>
        <ul class="list-payment" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li class="list-payment__item">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</footer>

