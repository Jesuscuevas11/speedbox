{% schema %}
{
  "name": "Footer Style 3",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mision",
      "default": "Nuestra mision en Elevate Rope es revolucionar el fitness cardiovascular y cambiar la percepcion negativa de los entrenamientos cardiovasculares en todo el mundo.\n\nNos esforzamos por hacer que el ejercicio cardiovascular sea accesible, agradable y divertido para todos, para que personas de todo el mundo puedan experimentar los beneficios de un estilo de vida saludable y activo."
    },
    {
      "type": "text",
      "id": "policy_title",
      "label": "Titulo columna politica",
      "default": "NUESTRA POLITICA"
    },
    {
      "type": "text",
      "id": "info_title",
      "label": "Titulo columna informacion",
      "default": "INFORMACION"
    },
    {
      "type": "text",
      "id": "hq_title",
      "label": "Titulo columna HQ",
      "default": "Elevate Rope HQ:"
    },
    {
      "type": "textarea",
      "id": "hq_text",
      "label": "Texto HQ",
      "default": "Numero de telefono: +31 6 12593028\n\nCorreo empresarial: support@elevaterope.com\n\nDireccion: Daltonstraat 17a, 3316 GD, Dordrecht, ZH, Paises Bajos."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright",
      "default": "© 2019 – 2025 Elevate Rope. Todos los derechos reservados. Elevate Rope es una marca registrada."
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Footer Style 3"
    }
  ]
}
{% endschema %}
