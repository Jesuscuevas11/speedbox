<section class="pdp-timeline section section--full-width" data-pdp-timeline>
  <div class="pdp-timeline__inner">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div
          class="pdp-timeline__item pdp-timeline__item--{{ block.settings.alignment }}"
          {% if forloop.first %}
            style="--after-height: 100%;"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="pdp-timeline__row">
            <div class="pdp-timeline__media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 660
                  | image_tag:
                    loading: 'lazy',
                    width: block.settings.image.width,
                    height: block.settings.image.height,
                    alt: block.settings.image_alt
                }}
              {% elsif block.settings.image_url != blank %}
                <img src="{{ block.settings.image_url }}" alt="{{ block.settings.image_alt | escape }}" loading="lazy" width="660" height="660">
              {% endif %}
            </div>
            <div class="pdp-timeline__content">
              <div class="pdp-timeline__content-inner">
                {% if block.settings.eyebrow != blank %}
                  <span>{{ block.settings.eyebrow }}</span>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h2 class="pdp-timeline__heading">{{ block.settings.heading }}</h2>
                {% endif %}
                <div class="pdp-timeline__description">{{ block.settings.description }}</div>
              </div>
            </div>
            <svg class="pdp-timeline__dot" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="8"></circle></svg>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <div class="pdp-timeline__item pdp-timeline__item--right" style="--after-height: 100%;"><div class="pdp-timeline__row"><div class="pdp-timeline__media"><img src="https://www.elevaterope.com/cdn/shop/files/elevate_app_with_play_store_and_app_store_icons.png?v=1742612172&width=660" alt="Aplicacion Elevate Shred" loading="lazy" width="660" height="660"></div><div class="pdp-timeline__content"><div class="pdp-timeline__content-inner"><span>Incluye:</span><h2 class="pdp-timeline__heading">ELEVATE SHRED</h2><div class="pdp-timeline__description"><h3>Aplicacion de Entrenamiento con Cuerda para Saltar</h3><p>Nuestra aplicacion complementaria de cuerda para saltar disenada para llevar tus entrenamientos al siguiente nivel.</p></div></div></div><svg class="pdp-timeline__dot" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="8"></circle></svg></div></div>
      <div class="pdp-timeline__item pdp-timeline__item--left"><div class="pdp-timeline__row"><div class="pdp-timeline__media"><img src="https://www.elevaterope.com/cdn/shop/files/Worldfissa-130-scaled.jpg?v=1742613027&width=660" alt="Aprobado por expertos" loading="lazy" width="660" height="990"></div><div class="pdp-timeline__content"><div class="pdp-timeline__content-inner"><span>Aprobado por:</span><div class="pdp-timeline__description"><h5>Expertos en Crossfit, boxeadores, campeones mundiales de salto con cuerda y miles de influencers de fitness en todo el mundo.</h5></div></div></div><svg class="pdp-timeline__dot" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="8"></circle></svg></div></div>
      <div class="pdp-timeline__item pdp-timeline__item--right"><div class="pdp-timeline__row"><div class="pdp-timeline__media"><img src="https://www.elevaterope.com/cdn/shop/files/MArco-Testi.jpg?v=1742613027&width=660" alt="Razon para elegir elevate" loading="lazy" width="660" height="554"></div><div class="pdp-timeline__content"><div class="pdp-timeline__content-inner"><div class="pdp-timeline__description"><h6><strong>Y esta es la razon:</strong></h6><p><strong>Experiencia definitiva de salto con cuerda:</strong> disenado para principiantes y saltadores competitivos.</p></div></div></div><svg class="pdp-timeline__dot" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="8"></circle></svg></div></div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "PDP Timeline",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline item",
      "settings": [
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "default": "right",
          "options": [
            {"value": "left", "label": "Left"},
            {"value": "right", "label": "Right"}
          ]
        },
        {"type": "image_picker", "id": "image", "label": "Image"},
        {"type": "text", "id": "image_url", "label": "Image URL fallback", "default": ""},
        {"type": "text", "id": "image_alt", "label": "Image alt", "default": "Timeline image"},
        {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Incluye:"},
        {"type": "text", "id": "heading", "label": "Heading", "default": "ELEVATE SHRED"},
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<h3>Aplicacion de Entrenamiento con Cuerda para Saltar</h3><p>Nuestra aplicacion complementaria de cuerda para saltar disenada para llevar tus entrenamientos al siguiente nivel.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Timeline",
      "blocks": [
        {
          "type": "timeline_item",
          "settings": {
            "alignment": "right",
            "eyebrow": "Incluye:",
            "heading": "ELEVATE SHRED",
            "description": "<h3>Aplicacion de Entrenamiento con Cuerda para Saltar</h3><p>Nuestra aplicacion complementaria de cuerda para saltar disenada para llevar tus entrenamientos al siguiente nivel.</p><p><strong>Programacion para todos los niveles:</strong> Ya seas principiante o un saltador avanzado, nuestra aplicacion ofrece programas adaptados a tu nivel.</p>"
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "alignment": "left",
            "eyebrow": "Aprobado por:",
            "heading": "",
            "description": "<h5>Expertos en Crossfit, boxeadores, campeones mundiales de salto con cuerda y miles de influencers de fitness en todo el mundo.</h5>"
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "alignment": "right",
            "eyebrow": "",
            "heading": "",
            "description": "<h6><strong>Y esta es la razon:</strong></h6><p><strong>Experiencia definitiva de salto con cuerda:</strong> disenado para principiantes y saltadores competitivos.</p><p><strong>Sin enredos y versatil:</strong> promete cero enredos y menos tropiezos.</p>"
          }
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
