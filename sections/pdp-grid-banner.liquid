<section class="pdp-grid-banner section section--full-width" data-pdp-grid-banner>
  <div class="pdp-grid-banner__inner">
    <div class="pdp-grid-banner__grid">
      <article class="pdp-grid-banner__card pdp-grid-banner__card--text">
        <h4 class="pdp-grid-banner__kicker">INCLUYE :</h4>
        <h5 class="pdp-grid-banner__headline">1X CUERDA CON PERLAS</h5>
        <p class="pdp-grid-banner__description">
          Las cuerdas con cuentas son perfectas para quienes buscan practicar trucos, envolturas de estilo libre,
          liberaciones y explorar el mundo del salto de cuerda estilo libre.
        </p>
      </article>

      <article class="pdp-grid-banner__card pdp-grid-banner__card--image">
        <img src="https://www.elevaterope.com/cdn/shop/files/Copy-of-Beaded-Jump-Rope-Lynx.png?v=1745700849&width=1500" alt="Lynx - Beaded Jump Rope - Elevate Rope" loading="lazy" width="1250" height="1250">
      </article>

      <article class="pdp-grid-banner__card pdp-grid-banner__card--image">
        <img src="https://www.elevaterope.com/cdn/shop/files/speed_rope_comparison_image.webp?v=1742608446&width=1500" alt="Comparacion de cuerdas" loading="lazy" width="1650" height="1250">
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP Grid Banner",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [],
  "presets": [{"name": "PDP Grid Banner"}]
}
{% endschema %}
