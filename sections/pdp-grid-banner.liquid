<section class="pdp-grid-banner section section--full-width" data-pdp-grid-banner>
  <div class="pdp-grid-banner__inner">
    <div class="pdp-grid-banner__grid">
      <article class="pdp-grid-banner__card pdp-grid-banner__card--text">
        <h4 class="pdp-grid-banner__kicker">{{ section.settings.kicker }}</h4>
        <h5 class="pdp-grid-banner__headline">{{ section.settings.headline }}</h5>
        <p class="pdp-grid-banner__description">{{ section.settings.description }}</p>
      </article>

      <article class="pdp-grid-banner__card pdp-grid-banner__card--image">
        {% if section.settings.image_1 != blank %}
          {{
            section.settings.image_1
            | image_url: width: 1500
            | image_tag:
              loading: 'lazy',
              width: section.settings.image_1.width,
              height: section.settings.image_1.height,
              alt: section.settings.image_1_alt
          }}
        {% elsif section.settings.image_1_url != blank %}
          <img src="{{ section.settings.image_1_url }}" alt="{{ section.settings.image_1_alt | escape }}" loading="lazy" width="1250" height="1250">
        {% endif %}
      </article>

      <article class="pdp-grid-banner__card pdp-grid-banner__card--image">
        {% if section.settings.image_2 != blank %}
          {{
            section.settings.image_2
            | image_url: width: 1500
            | image_tag:
              loading: 'lazy',
              width: section.settings.image_2.width,
              height: section.settings.image_2.height,
              alt: section.settings.image_2_alt
          }}
        {% elsif section.settings.image_2_url != blank %}
          <img src="{{ section.settings.image_2_url }}" alt="{{ section.settings.image_2_alt | escape }}" loading="lazy" width="1650" height="1250">
        {% endif %}
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP Grid Banner",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [
    {"type": "text", "id": "kicker", "label": "Kicker", "default": "INCLUYE :"},
    {"type": "text", "id": "headline", "label": "Headline", "default": "1X CUERDA CON PERLAS"},
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Las cuerdas con cuentas son perfectas para quienes buscan practicar trucos, envolturas de estilo libre, liberaciones y explorar el mundo del salto de cuerda estilo libre."
    },
    {"type": "image_picker", "id": "image_1", "label": "Image 1"},
    {"type": "text", "id": "image_1_url", "label": "Image 1 URL fallback", "default": "https://www.elevaterope.com/cdn/shop/files/Copy-of-Beaded-Jump-Rope-Lynx.png?v=1745700849&width=1500"},
    {"type": "text", "id": "image_1_alt", "label": "Image 1 alt", "default": "Lynx - Beaded Jump Rope - Elevate Rope"},
    {"type": "image_picker", "id": "image_2", "label": "Image 2"},
    {"type": "text", "id": "image_2_url", "label": "Image 2 URL fallback", "default": "https://www.elevaterope.com/cdn/shop/files/speed_rope_comparison_image.webp?v=1742608446&width=1500"},
    {"type": "text", "id": "image_2_alt", "label": "Image 2 alt", "default": "Comparacion de cuerdas"}
  ],
  "presets": [{"name": "PDP Grid Banner"}]
}
{% endschema %}
