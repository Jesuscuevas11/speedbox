    },
    {"type": "text", "id": "badge_text", "label": "Badge text", "default": "Why Choose Elevate Rope"},
    {"type": "text", "id": "title_line_1", "label": "Title line 1", "default": "Transform Your Fitness in"},
    {"type": "text", "id": "title_line_2", "label": "Title line 2", "default": "Half the Time"},
