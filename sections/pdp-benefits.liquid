        {"type": "text", "id": "problem_title", "label": "Problem title", "default": "Spending hours at the gym with minimal results?"},
        {"type": "text", "id": "solution_label", "label": "Solution label", "default": "THE SOLUTION"},
        {"type": "text", "id": "solution_title", "label": "Solution title", "default": "Burn 1,000+ calories per hour"},
        {"type": "textarea", "id": "description", "label": "Description", "default": "Jump rope torches more calories than running, cycling, or most gym workouts in half the time. Get a full-body cardio workout that delivers real results, fast."},
        {"type": "text", "id": "stat_value", "label": "Stat value", "default": "1,000"},
        {"type": "text", "id": "stat_color_class", "label": "Stat color class", "default": "pdp-benefits__stat-number--orange"},
        {"type": "text", "id": "stat_label", "label": "Stat label", "default": "calories/hour"}
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Benefits",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon_color_class": "pdp-benefits__icon--orange",
            "problem_title": "Spending hours at the gym with minimal results?",
            "solution_title": "Burn 1,000+ calories per hour",
            "description": "Jump rope torches more calories than running, cycling, or most gym workouts in half the time. Get a full-body cardio workout that delivers real results, fast.",
            "stat_value": "1,000",
            "stat_color_class": "pdp-benefits__stat-number--orange",
            "stat_label": "calories/hour"
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg>",
            "icon_color_class": "pdp-benefits__icon--purple",
            "problem_title": "Tired of commuting to crowded gyms?",
            "solution_title": "Train anywhere, anytime",
            "description": "No gym membership required. Your jump rope fits in your bag and works anywhere: home, park, hotel room, or backyard. Total fitness freedom in your pocket.",
            "stat_value": "10 mins",
            "stat_color_class": "pdp-benefits__stat-number--purple",
            "stat_label": "to setup"
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1\"></path><path d=\"M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4\"></path></svg>",
