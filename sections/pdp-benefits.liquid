<section class="pdp-benefits section section--full-width" data-pdp-benefits>
  <div class="pdp-benefits__inner">
    <header class="pdp-benefits__header">
      <div class="pdp-benefits__badge">
        {{ section.settings.badge_icon_svg }}
        {{ section.settings.badge_text }}
      </div>
      <h2 class="pdp-benefits__title">{{ section.settings.title_line_1 }}<br><span>{{ section.settings.title_line_2 }}</span></h2>
      <p class="pdp-benefits__subtitle">{{ section.settings.subtitle }}</p>
    </header>

    <div class="pdp-benefits__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <article class="pdp-benefits__card" {{ block.shopify_attributes }}>
            <div class="pdp-benefits__card-bg"></div>
            <div class="pdp-benefits__card-content">
              <div class="pdp-benefits__icon {{ block.settings.icon_color_class }}">
                {{ block.settings.icon_svg }}
              </div>
              <p class="pdp-benefits__label">{{ block.settings.problem_label }}</p>
              <h3 class="pdp-benefits__problem">{{ block.settings.problem_title }}</h3>
              <div class="pdp-benefits__divider"></div>
              <p class="pdp-benefits__label pdp-benefits__label--solution">{{ block.settings.solution_label }}</p>
              <h4 class="pdp-benefits__solution">{{ block.settings.solution_title }}</h4>
              <p class="pdp-benefits__description">{{ block.settings.description }}</p>
              <div class="pdp-benefits__stat">
                <span class="pdp-benefits__stat-number {{ block.settings.stat_color_class }}">{{ block.settings.stat_value }}</span>
                <span>{{ block.settings.stat_label }}</span>
              </div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <article class="pdp-benefits__card"><div class="pdp-benefits__card-bg"></div><div class="pdp-benefits__card-content"><div class="pdp-benefits__icon pdp-benefits__icon--orange"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path></svg></div><p class="pdp-benefits__label">THE PROBLEM</p><h3 class="pdp-benefits__problem">Spending hours at the gym with minimal results?</h3><div class="pdp-benefits__divider"></div><p class="pdp-benefits__label pdp-benefits__label--solution">THE SOLUTION</p><h4 class="pdp-benefits__solution">Burn 1,000+ calories per hour</h4><p class="pdp-benefits__description">Jump rope torches more calories than running, cycling, or most gym workouts in half the time. Get a full-body cardio workout that delivers real results, fast.</p><div class="pdp-benefits__stat"><span class="pdp-benefits__stat-number pdp-benefits__stat-number--orange">1,000</span><span>calories/hour</span></div></div></article>
        <article class="pdp-benefits__card"><div class="pdp-benefits__card-bg"></div><div class="pdp-benefits__card-content"><div class="pdp-benefits__icon pdp-benefits__icon--purple"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg></div><p class="pdp-benefits__label">THE PROBLEM</p><h3 class="pdp-benefits__problem">Tired of commuting to crowded gyms?</h3><div class="pdp-benefits__divider"></div><p class="pdp-benefits__label pdp-benefits__label--solution">THE SOLUTION</p><h4 class="pdp-benefits__solution">Train anywhere, anytime</h4><p class="pdp-benefits__description">No gym membership required. Your jump rope fits in your bag and works anywhere: home, park, hotel room, or backyard. Total fitness freedom in your pocket.</p><div class="pdp-benefits__stat"><span class="pdp-benefits__stat-number pdp-benefits__stat-number--purple">10 mins</span><span>to setup</span></div></div></article>
        <article class="pdp-benefits__card"><div class="pdp-benefits__card-bg"></div><div class="pdp-benefits__card-content"><div class="pdp-benefits__icon pdp-benefits__icon--green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"></path><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"></path></svg></div><p class="pdp-benefits__label">THE PROBLEM</p><h3 class="pdp-benefits__problem">Wasting money on expensive gym memberships?</h3><div class="pdp-benefits__divider"></div><p class="pdp-benefits__label pdp-benefits__label--solution">THE SOLUTION</p><h4 class="pdp-benefits__solution">One-time investment, lifetime results</h4><p class="pdp-benefits__description">Cancel your monthly membership. This is a one-time purchase that pays for itself quickly, with zero recurring fees.</p><div class="pdp-benefits__stat"><span class="pdp-benefits__stat-number pdp-benefits__stat-number--green">EUR 0</span><span>monthly fees</span></div></div></article>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP Benefits",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [
