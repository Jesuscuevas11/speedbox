        {"type": "text", "id": "stat_value", "label": "Valor de la estadistica", "default": "1,000"},
        {"type": "text", "id": "stat_color_class", "label": "Clase de color de la estadistica", "default": "pdp-benefits__stat-number--orange"},
        {"type": "text", "id": "stat_label", "label": "Etiqueta de la estadistica", "default": "calorias/hora"}
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios PDP",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon_color_class": "pdp-benefits__icon--orange",
            "problem_title": "Pasas horas en el gimnasio con resultados minimos?",
            "solution_title": "Quema mas de 1.000 calorias por hora",
            "description": "La cuerda para saltar quema mas calorias que correr, montar en bicicleta o la mayoria de los entrenamientos de gimnasio en la mitad del tiempo. Consigue un entrenamiento de cardio de cuerpo completo que da resultados reales, rapido.",
            "stat_value": "1,000",
            "stat_color_class": "pdp-benefits__stat-number--orange",
            "stat_label": "calorias/hora"
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg>",
