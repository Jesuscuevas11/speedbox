

<div class="section-background announcement-bar-background color-{{ section.settings.color_scheme }}"></div>
<aside
  class="announcement-bar spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --border-bottom-width: {{ section.settings.divider_width }}px;
    --announcement-duration: {{ section.settings.speed | times: 6 }}s;
  "
>
  <div class="announcement-bar-wrapper marquee">
    <div class="marquee__content" aria-live="polite">
      {% for repeat in (1..3) %}
        <div class="marquee_annoucement list-inline" {% if repeat > 1 %}aria-hidden="true"{% endif %}>
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% liquid
                assign plain_text = block.settings.text | strip_newlines | strip_html | strip
                assign fallback_message = 'ENVIO GRATIS A PARTIR DE 125 EUR'
                assign message_slot = forloop.index0 | modulo: 4
                case message_slot
                  when 1
                    assign fallback_message = 'GARANTIA DE POR VIDA (MANIJAS)'
                  when 2
                    assign fallback_message = '90 DIAS DE DEVOLUCIONES GRATIS'
                  when 3
                    assign fallback_message = 'LOVED BY 50,000+ HAPPY CUSTOMERS'
                endcase
                assign block_message = plain_text
                if block_message == ''
                  assign block_message = fallback_message
                endif
              %}
              <div
                class="announcement-bar__item"
                role="region"
                aria-label="Anuncio"
                {% if repeat == 1 %}
                  {{ block.shopify_attributes }}
                {% endif %}
              >
                {% if block.settings.link != blank %}
                  <a class="announcement-bar__link link link--text focus-inset animate-arrow" href="{{ block.settings.link }}">
                    <p class="announcement-bar__message h5">{{ block_message }}</p>
                  </a>
                {% else %}
                  <p class="announcement-bar__message h5">{{ block_message }}</p>
                {% endif %}
              </div>
            {% endfor %}
          {% else %}
            <div class="announcement-bar__item" role="region" aria-label="Anuncio">
              <a class="announcement-bar__link link link--text focus-inset animate-arrow" href="/es/collections/all">
                <p class="announcement-bar__message h5">ENVIO GRATIS A PARTIR DE 125 EUR</p>
              </a>
            </div>
            <div class="announcement-bar__item" role="region" aria-label="Anuncio">
              <p class="announcement-bar__message h5">GARANTIA DE POR VIDA (MANIJAS)</p>
            </div>
            <div class="announcement-bar__item" role="region" aria-label="Anuncio">
              <p class="announcement-bar__message h5">90 DIAS DE DEVOLUCIONES GRATIS</p>
            </div>
            <div class="announcement-bar__item" role="region" aria-label="Anuncio">
              <p class="announcement-bar__message h5">LOVED BY 50,000+ HAPPY CUSTOMERS</p>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</aside>

{% stylesheet %}
  .announcement-bar {
    --announcement-bar-height: 32.8px;
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    position: relative;
    z-index: 4;
    color: #ffffff;
    background-color: rgb(85, 16, 221) !important;
    padding-block: 0 !important;
    height: var(--announcement-bar-height);
    min-height: var(--announcement-bar-height);
  }

  .announcement-bar-background {
    background: rgb(85, 16, 221) !important;
  }

  .announcement-bar-wrapper {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .marquee {
    width: 100%;
    height: var(--announcement-bar-height);
    overflow: hidden;
    position: relative;
    white-space: nowrap;
  }

  .marquee__content {
    width: 300%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    animation: announcement-marquee var(--announcement-duration) linear infinite;
    will-change: transform;
  }

  .marquee__content:hover {
    animation-play-state: paused;
  }

  .marquee_annoucement {
    display: flex;
    align-items: center;
    flex: 0 0 33.3333%;
    min-width: 33.3333%;
    justify-content: space-around;
    gap: clamp(2rem, 7vw, 9rem);
    padding-inline: clamp(1rem, 2vw, 2rem);
  }

  .list-inline {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .announcement-bar__item {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--announcement-bar-height);
  }

  .announcement-bar__link {
    position: static;
    text-decoration: none;
  }

  .announcement-bar__message {
    margin: 0;
    font-size: 0.875rem;
    line-height: var(--announcement-bar-height);
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .announcement-bar .link,
  .announcement-bar .link:hover,
  .announcement-bar .link:focus-visible,
  .announcement-bar .animate-arrow,
  .announcement-bar .animate-arrow::after {
    color: #ffffff;
  }

  @keyframes announcement-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-66.6667%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__content {
      animation: none;
    }
  }

  @media screen and (max-width: 989px) {
    .marquee_annoucement {
      gap: clamp(1.25rem, 5vw, 3rem);
      padding-inline-end: clamp(1.25rem, 5vw, 3rem);
    }

    .announcement-bar__message {
      font-size: 0.8125rem;
      line-height: var(--announcement-bar-height);
    }
  }

  @media screen and (max-width: 749px) {
    .announcement-bar {
      --announcement-bar-height: 31.2px !important;
    }

    .announcement-bar__message {
      letter-spacing: 0.02em;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "t:settings.color_scheme"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement",
          "settings": {
            "text": "ENVIO GRATIS A PARTIR DE 125 €",
            "link": "/es/collections/all"
          }
        },
        "announcement_2": {
          "type": "_announcement",
          "settings": {
            "text": "GARANTIA DE POR VIDA (MANIJAS)"
          }
        },
        "announcement_3": {
          "type": "_announcement",
          "settings": {
            "text": "90 DIAS DE DEVOLUCIONES GRATIS"
          }
        },
        "announcement_4": {
          "type": "_announcement",
          "settings": {
            "text": "LOVED BY 50,000+ HAPPY CUSTOMERS"
          }
        }
      },
      "block_order": ["announcement_1", "announcement_2", "announcement_3", "announcement_4"]
    }
  ]
}
{% endschema %}
