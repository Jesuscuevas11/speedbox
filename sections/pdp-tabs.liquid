<section class="pdp-tabs section section--full-width" data-pdp-tabs>
  <div class="pdp-tabs__inner">
    <div class="pdp-tabs__wrapper" data-align="center">
      <ul class="pdp-tabs__nav" role="tablist" aria-label="{{ section.settings.nav_aria_label }}">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% assign tab_id = 'tab' | append: forloop.index %}
            <li class="{% if forloop.first %}is-active{% endif %}" role="presentation" {{ block.shopify_attributes }}>
              <button type="button" class="pdp-tabs__tab" data-tab-target="{{ tab_id }}" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">
                <span>{{ block.settings.label }}</span>
              </button>
            </li>
          {% endfor %}
        {% else %}
          <li class="is-active" role="presentation"><button type="button" class="pdp-tabs__tab" data-tab-target="tab1" role="tab" aria-selected="true"><span>COMPRA</span></button></li>
          <li role="presentation"><button type="button" class="pdp-tabs__tab" data-tab-target="tab2" role="tab" aria-selected="false"><span>ENVIO</span></button></li>
          <li role="presentation"><button type="button" class="pdp-tabs__tab" data-tab-target="tab3" role="tab" aria-selected="false"><span>LONGITUD DE LA CUERDA DE SALTO</span></button></li>
          <li role="presentation"><button type="button" class="pdp-tabs__tab" data-tab-target="tab4" role="tab" aria-selected="false"><span>TRUCOS DE APRENDIZAJE</span></button></li>
          <li role="presentation"><button type="button" class="pdp-tabs__tab" data-tab-target="tab5" role="tab" aria-selected="false"><span>LA FAMILIA ELEVATE</span></button></li>
        {% endif %}
      </ul>

      <div class="pdp-tabs__content">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% assign tab_id = 'tab' | append: forloop.index %}
            <article class="pdp-tabs__panel {% if forloop.first %}is-active{% endif %}" id="{{ tab_id }}" role="tabpanel" {{ block.shopify_attributes }}>
              <button type="button" class="pdp-tabs__mobile-title"><span>{{ block.settings.label }}</span></button>
              <div class="pdp-tabs__panel-inner">{{ block.settings.content }}</div>
            </article>
          {% endfor %}
        {% else %}
          <article class="pdp-tabs__panel is-active" id="tab1" role="tabpanel"><button type="button" class="pdp-tabs__mobile-title"><span>COMPRA</span></button><div class="pdp-tabs__panel-inner"><h6>Preguntas y respuestas sobre la compra de una nueva cuerda para saltar</h6><h5>P:1</h5><h3>No estoy seguro de que cuerda elegir ?</h3><p>Entendemos completamente si eres nuevo en el salto con cuerda.</p></div></article>
          <article class="pdp-tabs__panel" id="tab2" role="tabpanel"><button type="button" class="pdp-tabs__mobile-title"><span>ENVIO</span></button><div class="pdp-tabs__panel-inner"><h6>Preguntas y respuestas sobre envios y devoluciones</h6><h5>P:1</h5><h3>Cual es su politica de devoluciones?</h3><p>Puedes devolver tu pedido hasta 90 dias despues de recibirlo si no fue usado.</p></div></article>
          <article class="pdp-tabs__panel" id="tab3" role="tabpanel"><button type="button" class="pdp-tabs__mobile-title"><span>LONGITUD DE LA CUERDA DE SALTO</span></button><div class="pdp-tabs__panel-inner"><h6>Preguntas y respuestas sobre longitud de cuerda</h6><h5>Q:1</h5><h3>Son ajustables en longitud tus cuerdas para saltar?</h3><p>Si. Todas nuestras cuerdas son ajustables para adaptarse a tu altura y estilo de salto.</p></div></article>
          <article class="pdp-tabs__panel" id="tab4" role="tabpanel"><button type="button" class="pdp-tabs__mobile-title"><span>TRUCOS DE APRENDIZAJE</span></button><div class="pdp-tabs__panel-inner"><h6>Preguntas y respuestas sobre dominio de trucos</h6><h5>Q:1</h5><h3>Como puedo empezar a aprender trucos?</h3><p>Te recomendamos seguir una progresion para principiantes con practica constante y enfoque tecnico.</p></div></article>
          <article class="pdp-tabs__panel" id="tab5" role="tabpanel"><button type="button" class="pdp-tabs__mobile-title"><span>LA FAMILIA ELEVATE</span></button><div class="pdp-tabs__panel-inner"><h6>Preguntas y respuestas sobre la familia Elevate</h6><h5>Q:1</h5><h3>Como puedo unirme a la familia Elevate?</h3><p>Seleccionamos miembros por actitud, constancia y participacion en la comunidad.</p></div></article>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP Tabs",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [
    {"type": "text", "id": "nav_aria_label", "label": "Nav aria label", "default": "Informacion del producto"}
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {"type": "text", "id": "label", "label": "Label", "default": "TAB"},
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<h6>Titulo</h6><p>Contenido de la pestana.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "label": "COMPRA",
            "content": "<h6>Preguntas y respuestas sobre la compra de una nueva cuerda para saltar</h6><h5>P:1</h5><h3>No estoy seguro de que cuerda elegir ?</h3><p>Entendemos completamente si eres nuevo en el salto con cuerda.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "ENVIO",
            "content": "<h6>Preguntas y respuestas sobre envios y devoluciones</h6><h5>P:1</h5><h3>Cual es su politica de devoluciones?</h3><p>Puedes devolver tu pedido hasta 90 dias despues de recibirlo si no fue usado.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "LONGITUD DE LA CUERDA DE SALTO",
            "content": "<h6>Preguntas y respuestas sobre longitud de cuerda</h6><h5>Q:1</h5><h3>Son ajustables en longitud tus cuerdas para saltar?</h3><p>Si. Todas nuestras cuerdas son ajustables para adaptarse a tu altura y estilo de salto.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "TRUCOS DE APRENDIZAJE",
            "content": "<h6>Preguntas y respuestas sobre dominio de trucos</h6><h5>Q:1</h5><h3>Como puedo empezar a aprender trucos?</h3><p>Te recomendamos seguir una progresion para principiantes con practica constante y enfoque tecnico.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "LA FAMILIA ELEVATE",
            "content": "<h6>Preguntas y respuestas sobre la familia Elevate</h6><h5>Q:1</h5><h3>Como puedo unirme a la familia Elevate?</h3><p>Seleccionamos miembros por actitud, constancia y participacion en la comunidad.</p>"
          }
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
