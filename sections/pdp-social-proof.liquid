{% liquid
  assign pdp_product = closest.product | default: product
  assign social_proof_id = 'SocialProof-' | append: section.id
  assign video_blocks = section.blocks | where: 'type', 'video_card'
  assign trust_blocks = section.blocks | where: 'type', 'trust_card'
%}

<section
  id="{{ social_proof_id }}"
  class="pdp-social-proof section section--full-width"
  data-social-proof
  data-product-image="{{ pdp_product.featured_image | image_url: width: 400 }}"
>
  <div class="pdp-social-proof__inner">
    <div class="pdp-social-proof__hero">
      <div class="pdp-social-proof__rating-block">
        <div class="pdp-social-proof__stars" aria-hidden="true"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
        <div class="pdp-social-proof__rating-value">{{ section.settings.rating_value }}</div>
        <div class="pdp-social-proof__rating-copy">{{ section.settings.rating_copy }}</div>
        <a href="{{ section.settings.reviews_link_url | default: 'https://www.elevaterope.com/pages/reviews' }}" class="pdp-social-proof__link" target="_blank" rel="noopener noreferrer">{{ section.settings.reviews_link_label }}</a>
      </div>

      <div class="pdp-social-proof__people">
        <div class="pdp-social-proof__avatars" aria-hidden="true">
          <span>{{ section.settings.avatar_1 }}</span>
          <span>{{ section.settings.avatar_2 }}</span>
          <span>{{ section.settings.avatar_3 }}</span>
          <span>{{ section.settings.avatar_4 }}</span>
          <span>{{ section.settings.avatar_5 }}</span>
        </div>
        <div class="pdp-social-proof__people-copy">{{ section.settings.athletes_line_1 }}<br><span>{{ section.settings.athletes_line_2 }}</span></div>
      </div>
    </div>

    <div class="pdp-social-proof__activity-bar">
      <div class="pdp-social-proof__activity-item">
        <svg class="pdp-social-proof__activity-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle></svg>
        <span><strong data-viewer-count>{{ section.settings.viewer_count }}</strong> {{ section.settings.viewer_copy }}</span>
      </div>

      <div class="pdp-social-proof__activity-item">
        <svg class="pdp-social-proof__activity-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        <span>{{ section.settings.last_order_prefix }} <strong>{{ section.settings.last_order_emphasis }}</strong></span>
      </div>

      <div class="pdp-social-proof__delivery-pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"></rect><path d="M16 8h5l3 3v5h-3"></path><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        <span>{{ section.settings.countdown_prefix }} <strong data-countdown>{{ section.settings.countdown_value }}</strong> {{ section.settings.countdown_suffix }}</span>
      </div>
    </div>

    <div class="pdp-social-proof__gallery-block">
      <div class="pdp-social-proof__gallery-header">
        <h3>{{ section.settings.gallery_heading }}</h3>
        <a href="{{ section.settings.gallery_link_url | default: 'https://www.elevaterope.com/pages/reviews' }}" class="pdp-social-proof__link" target="_blank" rel="noopener noreferrer">{{ section.settings.gallery_link_label }}</a>
      </div>

      <div class="pdp-social-proof__gallery-grid">
        {% if video_blocks.size > 0 %}
          {% for block in video_blocks %}
            <button type="button" class="pdp-social-proof__video-card" data-video-id="{{ block.settings.video_id }}" {{ block.shopify_attributes }}>
              <img src="https://img.youtube.com/vi/{{ block.settings.video_id }}/hqdefault.jpg" alt="{{ block.settings.alt | escape }}" loading="lazy">
              <span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span>
            </button>
          {% endfor %}
        {% else %}
          <button type="button" class="pdp-social-proof__video-card" data-video-id="3U5Bn-R5MLw"><img src="https://img.youtube.com/vi/3U5Bn-R5MLw/hqdefault.jpg" alt="Video de resena de cliente 1" loading="lazy"><span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span></button>
          <button type="button" class="pdp-social-proof__video-card" data-video-id="zX3fB4iTZfU"><img src="https://img.youtube.com/vi/zX3fB4iTZfU/hqdefault.jpg" alt="Video de resena de cliente 2" loading="lazy"><span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span></button>
          <button type="button" class="pdp-social-proof__video-card" data-video-id="ab-TSJ9YS9M"><img src="https://img.youtube.com/vi/ab-TSJ9YS9M/hqdefault.jpg" alt="Video de resena de cliente 3" loading="lazy"><span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span></button>
          <button type="button" class="pdp-social-proof__video-card" data-video-id="jroNtnSdogs"><img src="https://img.youtube.com/vi/jroNtnSdogs/hqdefault.jpg" alt="Video de resena de cliente 4" loading="lazy"><span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span></button>
          <button type="button" class="pdp-social-proof__video-card" data-video-id="N365_szEpaU"><img src="https://img.youtube.com/vi/N365_szEpaU/hqdefault.jpg" alt="Video de resena de cliente 5" loading="lazy"><span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span></button>
          <button type="button" class="pdp-social-proof__video-card" data-video-id="JQchw5EAoWE"><img src="https://img.youtube.com/vi/JQchw5EAoWE/hqdefault.jpg" alt="Video de resena de cliente 6" loading="lazy"><span class="pdp-social-proof__video-overlay"><span class="pdp-social-proof__play-button"></span></span></button>
        {% endif %}
      </div>
    </div>

    <div class="pdp-social-proof__trust-grid">
      {% if trust_blocks.size > 0 %}
        {% for block in trust_blocks %}
          <article class="pdp-social-proof__trust-card" {{ block.shopify_attributes }}>
            {{ block.settings.icon_svg }}
            <div>
              <h4 {% if block.settings.is_shipping %}data-shipping-title{% endif %}>{{ block.settings.title }}</h4>
              <p {% if block.settings.is_shipping %}data-shipping-description{% endif %}>{{ block.settings.description }}</p>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <article class="pdp-social-proof__trust-card"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg><div><h4>90 dias de garantia de devolucion</h4><p>Pruebalo sin riesgo durante 3 meses. No estas satisfecho? Reembolso completo, sin preguntas.</p></div></article>
        <article class="pdp-social-proof__trust-card"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg><div><h4>Garantia de por vida en mangos</h4><p>Mangos premium garantizados para siempre. Garantia de 90 dias en cables y cuerdas.</p></div></article>
        <article class="pdp-social-proof__trust-card"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg><div><h4 data-shipping-title>Envio gratis en compras superiores a EUR 50</h4><p data-shipping-description>Entrega rapida a UE, Reino Unido, EE. UU., Canada y Australia. Disponible en todo el mundo.</p></div></article>
      {% endif %}
    </div>
  </div>

  <div class="pdp-social-proof__notification" data-notification hidden>
    <img src="{{ pdp_product.featured_image | image_url: width: 200 }}" alt="{{ pdp_product.title | escape }}" data-notification-image>
    <div class="pdp-social-proof__notification-copy">
      <div data-notification-name>{{ section.settings.notification_name }}</div>
      <div data-notification-action>{{ section.settings.notification_action }}</div>
      <div data-notification-time>{{ section.settings.notification_time }}</div>
    </div>
    <button type="button" class="pdp-social-proof__notification-close" data-notification-close aria-label="Cerrar notificacion">x</button>
  </div>

  <div class="pdp-social-proof__modal" data-video-modal hidden>
    <div class="pdp-social-proof__modal-dialog">
      <button type="button" class="pdp-social-proof__modal-close" data-close-video aria-label="Cerrar video">x</button>
      <iframe data-video-frame src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen title="Video de resena de cliente"></iframe>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Resenas PDP",
  "tag": "section",
  "class": "section section--full-width",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [
    {"type": "text", "id": "rating_value", "label": "Rating", "default": "4.9"},
    {"type": "inline_richtext", "id": "rating_copy", "label": "Texto de calificacion", "default": "Basado en mas de 1,200 resenas verificadas"},
    {"type": "url", "id": "reviews_link_url", "label": "Reviews link"},
    {"type": "text", "id": "reviews_link_label", "label": "Etiqueta del enlace de resenas", "default": "Leer resenas de clientes"},

    {"type": "text", "id": "avatar_1", "label": "Avatar 1", "default": "SM"},
    {"type": "text", "id": "avatar_2", "label": "Avatar 2", "default": "MR"},
    {"type": "text", "id": "avatar_3", "label": "Avatar 3", "default": "AK"},
    {"type": "text", "id": "avatar_4", "label": "Avatar 4", "default": "JL"},
    {"type": "text", "id": "avatar_5", "label": "Avatar 5", "default": "ES"},
    {"type": "text", "id": "athletes_line_1", "label": "Linea de atletas 1", "default": "Unete a mas de 50,000 atletas"},
    {"type": "text", "id": "athletes_line_2", "label": "Linea de atletas 2", "default": "que confian en Elevate"},

    {"type": "text", "id": "viewer_count", "label": "Viewer count", "default": "38"},
    {"type": "text", "id": "viewer_copy", "label": "Texto de espectadores", "default": "personas viendo ahora mismo"},
    {"type": "text", "id": "last_order_prefix", "label": "Prefijo de ultimo pedido", "default": "Ultimo pedido"},
    {"type": "text", "id": "last_order_emphasis", "label": "Valor de ultimo pedido", "default": "hace 2 minutos"},
    {"type": "text", "id": "countdown_prefix", "label": "Prefijo de cuenta regresiva", "default": "Haz tu pedido en"},
    {"type": "text", "id": "countdown_value", "label": "Countdown value", "default": "18h 25m"},
    {"type": "text", "id": "countdown_suffix", "label": "Sufijo de cuenta regresiva", "default": "para envio el mismo dia"},

    {"type": "text", "id": "gallery_heading", "label": "Titulo de galeria", "default": "Clientes reales, resultados reales"},
    {"type": "url", "id": "gallery_link_url", "label": "Gallery link"},
    {"type": "text", "id": "gallery_link_label", "label": "Etiqueta del enlace de galeria", "default": "Ver todas las resenas"},

    {"type": "text", "id": "notification_name", "label": "Notification name", "default": "Carlos R. from Madrid"},
    {"type": "text", "id": "notification_action", "label": "Accion de notificacion", "default": "acaba de comprar Athlete Bundle"},
    {"type": "text", "id": "notification_time", "label": "Tiempo de notificacion", "default": "hace 2 minutos"}
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Tarjeta de video",
      "settings": [
        {"type": "text", "id": "video_id", "label": "YouTube video ID", "default": "3U5Bn-R5MLw"},
        {"type": "text", "id": "alt", "label": "Texto alternativo de imagen", "default": "Video de resena de cliente"}
      ]
    },
    {
      "type": "trust_card",
      "name": "Tarjeta de confianza",
      "settings": [
        {"type": "textarea", "id": "icon_svg", "label": "SVG icon", "default": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" aria-hidden=\"true\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path></svg>"},
        {"type": "text", "id": "title", "label": "Titulo", "default": "90 dias de garantia de devolucion"},
        {"type": "textarea", "id": "description", "label": "Descripcion", "default": "Pruebalo sin riesgo durante 3 meses. No estas satisfecho? Reembolso completo, sin preguntas."},
        {"type": "checkbox", "id": "is_shipping", "label": "Use shipping data attributes", "default": false}
      ]
    }
  ],
  "presets": [
    {
      "name": "Resenas PDP",
      "blocks": [
        {"type": "video_card", "settings": {"video_id": "3U5Bn-R5MLw", "alt": "Video de resena de cliente 1"}},
        {"type": "video_card", "settings": {"video_id": "zX3fB4iTZfU", "alt": "Video de resena de cliente 2"}},
        {"type": "video_card", "settings": {"video_id": "ab-TSJ9YS9M", "alt": "Video de resena de cliente 3"}},
        {"type": "video_card", "settings": {"video_id": "jroNtnSdogs", "alt": "Video de resena de cliente 4"}},
        {"type": "video_card", "settings": {"video_id": "N365_szEpaU", "alt": "Video de resena de cliente 5"}},
        {"type": "video_card", "settings": {"video_id": "JQchw5EAoWE", "alt": "Video de resena de cliente 6"}},
        {"type": "trust_card", "settings": {"title": "90 dias de garantia de devolucion", "description": "Pruebalo sin riesgo durante 3 meses. No estas satisfecho? Reembolso completo, sin preguntas."}},
        {"type": "trust_card", "settings": {"icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg>", "title": "Garantia de por vida en mangos", "description": "Mangos premium garantizados para siempre. Garantia de 90 dias en cables y cuerdas."}},
        {"type": "trust_card", "settings": {"icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" aria-hidden=\"true\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg>", "title": "Envio gratis en compras superiores a EUR 50", "description": "Entrega rapida a UE, Reino Unido, EE. UU., Canada y Australia. Disponible en todo el mundo.", "is_shipping": true}}
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
